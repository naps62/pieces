  "peerDependencies": {
    "@naps62/ui": "*",
    "drizzle-orm": ">=0.45.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "vite": ">=7.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.2.3",
    "drizzle-orm": "^0.45.2",
